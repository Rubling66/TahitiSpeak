{
  "name": "tahitispeak",
  "version": "1.0.0",
  "description": "TahitiSpeak - Interactive Tahitian Language Learning Platform",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rubling66/TahitiSpeak.git"
  },
  "homepage": "https://github.com/Rubling66/TahitiSpeak",
  "author": "Rubling66",
  "keywords": [
    "tahitian",
    "language-learning",
    "education",
    "nextjs",
    "react"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Rubling66/TahitiSpeak/issues"
  },
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:api": "tsx watch api/server.ts",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:api\"",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "build:standalone": "BUILD_STANDALONE=true next build",
    "start": "next start",
    "start:api": "tsx api/server.ts",
    "start:prod": "NODE_ENV=production next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "check": "npm run type-check && npm run lint",
    "check:env": "node scripts/check-env.js",
    "test:apis": "node scripts/test-apis.js",
    "health-check": "node scripts/health-check.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPatterns=tests/unit",
    "test:api": "jest --testPathPatterns=tests/api",
    "test:integration": "jest --testPathPatterns=tests/integration",
    "test:all": "npm run test:unit && npm run test:api",
    "test:ci": "jest --coverage --watchAll=false --testPathPatterns=tests/unit",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:performance": "lhci autorun",
    "test:accessibility": "axe http://localhost:3000",
    "test:validate": "node scripts/test-validation.js",
    "test:e2e:ui": "playwright test --ui",
    "test:a11y": "jest --testPathPattern=tests/accessibility",
    "test:build": "npm run build && npm run test:unit",
    "playwright:install": "playwright install",
    "db:migrate": "node scripts/migrate.js",
    "lhci": "lhci autorun",
    "analyze": "npm run build:analyze",
    "prebuild": "npm run check:env && npm run check",
    "postbuild": "npm run health-check"
  },
